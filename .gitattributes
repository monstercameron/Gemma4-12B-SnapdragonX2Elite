# Normalize line endings: scripts that must stay LF (bash) vs CRLF (PowerShell/Windows).
* text=auto eol=lf
*.sh   text eol=lf
*.py   text eol=lf
*.comp text eol=lf
*.ps1  text eol=crlf
*.bat  text eol=crlf

# Binaries (don't diff / don't touch EOL)
*.spv          binary
*.safetensors  binary
*.gguf         binary
*.onnx         binary
*.png          binary
