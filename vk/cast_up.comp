#version 450
#extension GL_EXT_shader_explicit_arithmetic_types_float16 : require
layout(local_size_x = 64) in;
layout(std430, binding=0) readonly  buffer S { float16_t src[]; };
layout(std430, binding=1) writeonly buffer D { float dst[]; };
layout(std140, binding=2) uniform U { uvec4 d; };
void main() { uint i = gl_GlobalInvocationID.x; if (i >= d.x) return; dst[i] = float(src[i]); }
